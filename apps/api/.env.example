# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://popstack:popstack_dev_password@localhost:5432/popstack

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://isighmfzzqaivrqmaimn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_string_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PLATFORM_FEE_PCT=15

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── DeepL ───────────────────────────────────────────────────────────────────
DEEPL_API_KEY=your_deepl_api_key_here

# ─── Resend ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@popstack.dev

# ─── Google Perspective (moderation) ─────────────────────────────────────────
PERSPECTIVE_API_KEY=your_perspective_api_key_here

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
